	/* CHECK: did we wake from standby? */
	if (__HAL_PWR_GET_FLAG(PWR_FLAG_SB) != RESET) {
		__HAL_PWR_CLEAR_FLAG(PWR_FLAG_SB);

		standby_counter++;

		sprintf(uart_buffer, "Standby counter = %lu\r\n", standby_counter);

		HAL_UART_Transmit(&huart2, (uint8_t*) uart_buffer, strlen(uart_buffer),
		HAL_MAX_DELAY);

		/* blink LED 3 times with 500 ms */
		for (int i = 0; i < 3; i++) {
			HAL_GPIO_WritePin(GPIOA, GPIO_PIN_10, GPIO_PIN_SET);

			HAL_Delay(500);

			HAL_GPIO_WritePin(GPIOA, GPIO_PIN_10, GPIO_PIN_RESET);

			HAL_Delay(500);
		}
	} else {
		/* first power-on indication */
		HAL_GPIO_WritePin(GPIOA, GPIO_PIN_10, GPIO_PIN_SET);

		HAL_Delay(1000);

		HAL_GPIO_WritePin(GPIOA, GPIO_PIN_10, GPIO_PIN_RESET);
	}

	HAL_Delay(500);

	/* go to standby again */
	Enter_Standby_Mode();
