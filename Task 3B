/* USER CODE BEGIN 0 */
uint32_t standby_counter = 0;
char uart_buffer[50];
void Enter_Standby_Mode(void) {
	// Clear Wakeup flag
	__HAL_PWR_CLEAR_FLAG(PWR_FLAG_WU);

	// Enable Wakeup pin
	HAL_PWR_EnableWakeUpPin(PWR_WAKEUP_PIN1);

	// Enter Standby
	HAL_PWR_EnterSTANDBYMode();
}
/* USER CODE END 0 */

